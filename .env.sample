# Telegram
TELEGRAM_BOT_TOKEN=

# CookMyBots AI Gateway
# COOKMYBOTS_AI_ENDPOINT is a BASE URL (do NOT include /chat)
COOKMYBOTS_AI_ENDPOINT=https://api.cookmybots.com/api/ai
COOKMYBOTS_AI_KEY=

# MongoDB (optional but recommended)
MONGODB_URI=

# Optional: admin user IDs (comma-separated Telegram user IDs)
BOT_ADMINS=

# Optional controls
AI_DEBUG=0
AI_TIMEOUT_MS=600000
AI_MAX_RETRIES=2
CONCURRENCY=20
